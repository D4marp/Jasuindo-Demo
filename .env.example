# Identity Verification Prototype - Environment Variables
# Copy this file to .env.local and fill in the values

# API Configuration (untuk integrasi future)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
# NEXT_PUBLIC_API_TIMEOUT=30000

# Optional: Face Recognition Service
# FACE_RECOGNITION_API_KEY=your_api_key_here
# FACE_RECOGNITION_API_URL=https://api.facerecognition.com

# Optional: Verification Service
# VERIFICATION_API_KEY=your_api_key_here
# VERIFICATION_API_URL=http://localhost:3001/api

# Environment
NODE_ENV=development
